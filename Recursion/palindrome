def palindrome(s):
    def check(left, right):
        length = right - left + 1
        if length == 1 or length == 0:
            return True
        if s[left] != s[right]:
            return False
        return check(left + 1, right - 1)

    return check(0, len(s) - 1)

s = 'naman'
print(palindrome(s))    